# Copy to .env and fill in. Never commit .env.

PORT=3000
NODE_ENV=production

# MongoDB connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.example/roomate?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=

# Brevo (email verification, notifications)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Public URL of this API (used in emails/links if referenced)
BACKEND_PUBLIC_URL=https://api.yourdomain.com

# Web app origin for CORS (if you have a web client)
FRONTEND_URL=https://app.yourdomain.com

# Optional: comma-separated extra allowed origins (marketing site, staging)
# ALLOWED_ORIGINS=https://www.yourdomain.com,https://staging.yourdomain.com

# Optional: Gemini for AI features
# GEMINI_API_KEY=
